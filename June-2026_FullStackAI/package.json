{
  "name": "agent-console-workspace",
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install --prefix agent-console && npm install --prefix agent-server",
    "dev": "npm run dev --prefix agent-console",
    "build": "npm run build --prefix agent-console",
    "start": "npm run start --prefix agent-console",
    "server:start": "npm start --prefix agent-server",
    "server:chaos": "npm run start --prefix agent-server -- --mode chaos"
  }
}
